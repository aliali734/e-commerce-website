# Server
PORT=3000
NODE_ENV=development
CLIENT_ORIGIN=https://aliali734.github.io

# Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017/ecommerce_db

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# CSRF
CSRF_SECRET=your_csrf_secret_here

# Session / Cookie
COOKIE_SECRET=your_cookie_secret_here
COOKIE_MAX_AGE=604800000

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password_here
EMAIL_FROM=no-reply@yourstore.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# Password Reset
# Frontend is served from GitHub Pages, backend from Render — these are
# genuinely two different origins.
# FRONTEND_URL points at GitHub Pages (used for links users click, e.g.
# password reset emails, and OAuth redirect targets after login).
# SERVER_URL points at this Render backend itself (used for OAuth
# callback URLs registered with Google/Facebook).
RESET_TOKEN_EXPIRES_MS=3600000
FRONTEND_URL=https://aliali734.github.io
SERVER_URL=https://e-commerce-website-j3yr.onrender.com

# Admin Registration
ADMIN_REGISTRATION_SECRET=your_admin_secret_here
