# Server
PORT=3000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017/ecommerce_db

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# CSRF
CSRF_SECRET=your_csrf_secret_here

# Session / Cookie
COOKIE_SECRET=your_cookie_secret_here
COOKIE_MAX_AGE=604800000

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password_here
EMAIL_FROM=no-reply@yourstore.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# Password Reset
# This project runs as a single Render service (one deployment serves
# both the frontend and the API), so FRONTEND_URL and SERVER_URL are
# currently the same value — your one Render URL, e.g.
# https://your-app.onrender.com. They're kept as two separate variables
# so that if you ever split the frontend into its own deployment later,
# only SERVER_URL needs to change (OAuth callbacks, cookie behavior)
# without touching FRONTEND_URL (the link users click in reset emails)
# or any application code.
RESET_TOKEN_EXPIRES_MS=3600000
FRONTEND_URL=http://localhost:3000
SERVER_URL=http://localhost:3000

# Admin Registration
ADMIN_REGISTRATION_SECRET=your_admin_secret_here
