# Server
PORT=3000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017/ecommerce_db

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# CSRF
CSRF_SECRET=your_csrf_secret_here

# Session / Cookie
COOKIE_SECRET=your_cookie_secret_here
COOKIE_MAX_AGE=604800000

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password_here
EMAIL_FROM=no-reply@yourstore.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# Password Reset
# FRONTEND_URL points at the client app (used to build links users click,
# e.g. the password reset email link).
# SERVER_URL points at this backend itself (used for OAuth callback URLs).
# They're the same value today since this is a monolith, but keeping them
# separate means only SERVER_URL needs to change if the frontend later
# moves to Vercel/Netlify while this backend stays on Render.
RESET_TOKEN_EXPIRES_MS=3600000
FRONTEND_URL=http://localhost:3000
SERVER_URL=http://localhost:3000

# Admin Registration
ADMIN_REGISTRATION_SECRET=your_admin_secret_here
